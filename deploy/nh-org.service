[Unit]
Description=Narrow Highway — .org (the witness: API + site, foundation named)
After=network.target

[Service]
User=nh
WorkingDirectory=/home/nh/concordance-2
EnvironmentFile=-/home/nh/concordance-2/.env
Environment=PYTHONPATH=/home/nh/concordance-2/src
Environment=CONCORDANCE_DATA_DIR=/home/nh/concordance-2/data
Environment=CONCORDANCE_STRONGS_DIR=/home/nh/concordance-2/data/strongs
ExecStart=/home/nh/concordance-2/.venv/bin/python -m concordance serve --host 127.0.0.1 --port 8001 --surface witness
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
