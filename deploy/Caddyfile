# Narrow Highway — Caddy reverse proxy (auto-TLS via Let's Encrypt).
# Two faces, one engine: .com is the secular reach, .org is the witness.
#
# CURRENT LIVE REALITY (2026-07-01): the .com -> 2.0 cutover is DONE. narrowhighway.com is
# served by 2.0 SECULAR (`nh-com-2` on :8002), with a path fallback to 1.0 (`nh-engine` on
# :8000) for the cited/crawled per-card permalinks so nothing indexed 404s. narrowhighway.org
# is 2.0 WITNESS (`nh-org` on :8001). api.narrowhighway.com and narrowhighway.tv stay on 1.0.
# Rollback of .com to 1.0: restore /etc/caddy/Caddyfile.bak.pre2cut and reload caddy.

api.narrowhighway.com {
	reverse_proxy 127.0.0.1:8000 {
		lb_try_duration 10s
		lb_try_interval 250ms
	}
	encode gzip zstd
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	log {
		output file /var/log/caddy/api.access.log
		format json
	}
}

narrowhighway.com {
	encode gzip zstd
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Preserve 1.0's cited/crawled per-card permalinks and their own assets so the
	# indexed card pages and ~186 AI citations never 404. These paths are 1.0-only
	# (2.0 uses /styles.css and its own paths) -> no collision with the new face.
	@onezero path /card.html* /card/* /nh-*
	handle @onezero {
		reverse_proxy 127.0.0.1:8000 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}

	# The new face: 2.0 secular owns the front door, the app, the engine, and the seals.
	handle {
		reverse_proxy 127.0.0.1:8002 {
			lb_try_duration 10s
			lb_try_interval 250ms
		}
	}

	log {
		output file /var/log/caddy/site.access.log
		format json
	}
}

narrowhighway.org {
	reverse_proxy 127.0.0.1:8001 {
		lb_try_duration 10s
		lb_try_interval 250ms
	}
	encode gzip zstd
}

narrowhighway.tv {
	reverse_proxy 127.0.0.1:8000 {
		lb_try_duration 10s
		lb_try_interval 250ms
	}
	encode gzip zstd
}
