# Narrow Highway — Caddy reverse proxy (auto-TLS via Let's Encrypt).
#
# CURRENT LIVE REALITY (2026-07-02): 1.0 (nh-engine :8000) is RETIRED — everything is 2.0.
#   narrowhighway.com      -> :8002  (2.0 secular; front door, app, engine, seals, card permalinks)
#   api.narrowhighway.com  -> :8002  (2.0 secular; verify/derivation.verify/search/seal/mcp/identity)
#   narrowhighway.org      -> :8001  (2.0 witness)
#   narrowhighway.tv       -> :8001  (2.0 witness; tv.html landing — watch/listen/learn)
# 1.0 files remain at /home/nh/Lighthouse (+ archive ~/backups/lighthouse-1.0-full-*.tar.gz);
# re-enable with `sudo systemctl enable --now nh-engine` and restore this file from a backup.
# Rollback points: .pre2cut (.com cutover), .pretv (.tv), .pre1retire (this 1.0 retirement).

api.narrowhighway.com {
	encode gzip zstd
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	# 1.0 retired — api served by 2.0 secular. 1.0-only granular endpoints are intentionally gone
	# (accepted MCP tool-parity delta: ~103 granular 1.0 tools -> 2.0's consolidated set).
	reverse_proxy 127.0.0.1:8002 {
		lb_try_duration 10s
		lb_try_interval 250ms
	}
	log {
		output file /var/log/caddy/api.access.log
		format json
	}
}

narrowhighway.com {
	encode gzip zstd
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Retired 1.0 lifestyle pages -> home (content archived, recoverable) so cited links don't hard-404.
	@legacy path /almanac.html /apothecary.html /walk.html /kept.html /enter.html /packets.html /breath.html /missions.html /search.html /voices
	redir @legacy / 301
	# Retired 1.0 pages -> their nearest 2.0 home (preserve crawl equity; no hard 404).
	redir /about.html /guarantees.html 301
	redir /today.html /journal.html 301
	redir /curriculum.html /read.html 301
	redir /submit-curriculum.html /read.html 301
	redir /workshop.html /read.html 301
	redir /guidance.html /ask.html 301
	redir /canon.html /bible.html 301
	redir /bibles.html /bible.html 301
	redir /bible-trivia.html /bible.html 301
	redir /reach.html /community.html 301
	redir /outreach.html /community.html 301
	redir /assembly.html /community.html 301
	redir /media-center.html https://narrowhighway.tv/ 301

	# 2.0 secular serves everything — front door, app, engine, seals, AND the card permalinks
	# (render_card_html at /card.html?id= and /card/<id>). No more 1.0 fallback.
	reverse_proxy 127.0.0.1:8002 {
		lb_try_duration 10s
		lb_try_interval 250ms
	}
	log {
		output file /var/log/caddy/site.access.log
		format json
	}
}

narrowhighway.org {
	reverse_proxy 127.0.0.1:8001 {
		lb_try_duration 10s
		lb_try_interval 250ms
	}
	encode gzip zstd
}

narrowhighway.tv {
	encode gzip zstd
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# The watch/listen/learn face on the 2.0 WITNESS engine (:8001); its landing is tv.html.
	@root path /
	rewrite @root /tv.html
	reverse_proxy 127.0.0.1:8001 {
		lb_try_duration 10s
		lb_try_interval 250ms
	}
	log {
		output file /var/log/caddy/tv.access.log
		format json
	}
}
